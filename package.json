{
  "name": "flick",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build && npm run verify:extension",
    "verify:extension": "node scripts/verify-extension.cjs",
    "version:bump": "node scripts/bump-extension-version.cjs",
    "release:prepare": "npm run version:bump && npm run verify"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
